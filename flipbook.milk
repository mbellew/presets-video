comp_1=```
shader_body
{
    // ---- scene layout (procedural book on a desk) ----
    // The painted frame (sampler_main) is drawn inside PAGE rect [P0..P1].
    // A page turns about the LEFT (spine) edge: as the turn angle q3 grows the
    // page foreshortens (covers pg.x in [0, cos(q3)]) and lifts, revealing the
    // next page underneath (the same freshly-baked image). Real page edges +
    // shading + a cast shadow give the 3D page-turn read.
    float2 P0 = float2(0.08, 0.06);
    float2 P1 = float2(0.92, 0.94);
    float3 desk = float3(0.06, 0.05, 0.045);

    // desk with a soft vignette
    float2 cc = uv - 0.5;
    float3 col = desk * (1.0 - dot(cc, cc) * 0.7);

    // gentle page arc: bow the whole page up in the middle so it isn't dead
    // flat. arc depends only on horizontal position, so it curves the top and
    // bottom edges (and the content) together by a small amount.
    float px  = (uv.x - P0.x) / (P1.x - P0.x);
    float arc = sin(clamp(px, 0.0, 1.0) * 3.14159265) * 0.035;
    float2 uva = float2(uv.x, uv.y + arc);   // + bows the page up in the middle

    // pg = 0..1 across the page; outside the rect it goes out of [0,1]
    float2 pg = (uva - P0) / (P1 - P0);
    float inpage = step(0.0, pg.x) * step(pg.x, 1.0)
                 * step(0.0, pg.y) * step(pg.y, 1.0);

    // soft drop shadow of the book onto the desk (follows the arced silhouette)
    float2 dout = max(max(P0 - uva, uva - P1), float2(0.0, 0.0));
    float shad = exp(-length(dout) * 45.0) * 0.75;
    col = lerp(col, desk * 0.15, shad * (1.0 - inpage));

    // card-stack edges: a few lines just beyond the right & bottom edges (they
    // follow the arced page contour) to imply a stack of pages under the top one.
    // NOTE: in this space pg.y = 0 is the TOP edge and pg.y = 1 is the BOTTOM,
    // so the bottom stack line sits at pg.y = 1 + o.
    float st = 0.0;
    int kk;
    for (kk = 1; kk <= 4; kk = kk + 1)
    {
        float o = float(kk) * 0.006;
        float rl = (1.0 - smoothstep(0.0, 0.0018, abs(pg.x - (1.0 + o)))) * step(0.0, pg.y) * step(pg.y, 1.0 + o);
        float bl = (1.0 - smoothstep(0.0, 0.0018, abs(pg.y - (1.0 + o)))) * step(0.0, pg.x) * step(pg.x, 1.0 + o);
        st = max(st, max(rl, bl) * (1.0 - float(kk) * 0.15));   // fainter deeper in the stack
    }
    col = lerp(col, float3(0.55, 0.52, 0.47), st * (1.0 - inpage));

    // aspect-fit ("cover"): sample a centered crop of the painting so its shape
    // isn't distorted to the page rectangle. Map page-local m -> buffer uv via
    //   buv = (m - 0.5) * fit + 0.5
    float bufAsp  = texsize.x / texsize.y;
    float pageAsp = ((P1.x - P0.x) * texsize.x) / ((P1.y - P0.y) * texsize.y);
    float2 fit = float2(1.0, 1.0);
    if (pageAsp > bufAsp) { fit.y = bufAsp / pageAsp; } else { fit.x = pageAsp / bufAsp; }

    if (inpage > 0.5)
    {
        float ct = cos(q3);                 // 1 = flat, 0 = edge-on / turned away

        // end-of-life zoom: push the content in toward the page center. q4 goes
        // 0 during the hold, then ramps; at full zoom the crop collapses to one
        // color, and we lerp the last bit to a flat monocolor for a clean end.
        float2 focal = float2(0.5, 0.5);
        float zoom = 1.0 + q4 * q4 * 16.0;

        float3 pagecol;
        if (pg.x < ct)
        {
            // --- on the turning page (foreshortened toward the spine) ---
            float u_ = pg.x / max(ct, 0.001);          // material coord 0..1
            float2 m1 = focal + (float2(u_, pg.y) - focal) / zoom;
            pagecol = tex2D(sampler_main, (m1 - 0.5) * fit + 0.5).xyz;
            float shade = 0.55 + 0.45 * ct;            // flatter -> brighter
            float hi = smoothstep(0.8, 1.0, u_) * (1.0 - ct) * 0.6; // edge catchlight
            pagecol = pagecol * shade + hi;
        }
        else
        {
            // --- next page revealed underneath (un-foreshortened) ---
            float2 m1 = focal + (pg - focal) / zoom;
            pagecol = tex2D(sampler_main, (m1 - 0.5) * fit + 0.5).xyz;
            float cs = saturate(1.0 - (pg.x - ct) / 0.06) * 0.55; // cast shadow at fold
            pagecol = pagecol * (1.0 - cs);
        }

        // thin page-stack / spine shading along the left binding edge
        float spine = smoothstep(0.03, 0.0, pg.x) * 0.5;
        pagecol = pagecol * (1.0 - spine);

        // faint light crest along the arc so the curve reads
        pagecol = pagecol * (1.0 + (arc / 0.035) * 0.05);

        // (no monocolor resolve: the ending is a flurry of blank page-turns,
        //  baked white by the warp shader when q6 is set)

        col = pagecol;
    }

    ret = col;
}
```
