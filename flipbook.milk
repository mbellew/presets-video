// FLIPBOOK - live video stylised as an artist's flipbook on a desk.
//
// Every ~1/2 s a new "page" is drawn: the warp shader runs ONE of four artistic
// filters over the incoming video (picked once per preset from rand_preset, so a
// given run stays in one style):
//   0 watercolor  - Kuwahara flatten + saturate + posterize; seg-whitened bg
//   1 charcoal    - Sobel strokes + tonal shading + paper grain on warm paper
//   2 line drawing - multi-scale Sobel contours + posterized ink wash (subject)
//   3 comic book  - CMYK-quantised cels + Ben-Day halftone + ink; desaturated bg
// The chosen filter is expensive, so it is baked only on the "gate" frame and the
// painted result is held in the feedback buffer between pages.
//
// The comp shader composites the scene: the held page is drawn (aspect-fit, with
// a gentle arc) into a page rectangle on a vignetted desk, with a drop shadow and
// card-stack edges. At each turn the page foreshortens and lifts about its left
// spine (angle q3) to reveal the next page, giving the 3D page-turn read.
//
// LIFETIME: normal flipbook, then a zoom into centre resolving to a flat mono-
// colour, then per_frame sets preset_complete to hand off (flipbooks are short).
//
// NOTE: in the comp pixel shader uv.y = 0 is the TOP edge (y increases downward).
[preset00]
MILKDROP_PRESET_VERSION=201
PSVERSION=2
PSVERSION_WARP=2
PSVERSION_COMP=2

// Identity transform + no decay so a held (painted) frame stays pixel-exact.
fWaveEnable=0
fDecay=1
zoom=1
rot=0
cx=0.5
cy=0.5
dx=0
dy=0
warp=0
sx=1
sy=1
wave_a=0

per_frame_init_1=last_t = 0;
per_frame_init_2=pstart = -1;
per_frame_init_3=fired = 0;
per_frame_init_4=blanked = 0;

// Straight video copy, no library-computed alpha.
per_frame_1=video_alpha_mode = 0;
per_frame_2=video_alpha_value = 1.0;
per_frame_3=video_alpha_init = 0.0;

// --- lifetime timeline (computed first: it drives the flip cadence below) ---
// hold (normal flipbook) -> zoom in -> a flurry of blank end-pages -> end.
per_frame_4=pstart = if(below(pstart, 0), time, pstart);   // capture preset start once
per_frame_5=age = time - pstart;                            // seconds since preset start
per_frame_6=THOLD = 12.0;      // normal flipbook
per_frame_7=TZOOM = 2.0;       // zoom-in lead-in
per_frame_8=TBLANK = 1.1;      // blank end-page flurry
per_frame_9=zend = THOLD + TZOOM;
per_frame_10=blank = above(age, zend);                     // 1 during the blank end-pages
per_frame_11=enterblank = blank * equal(blanked, 0);       // one-shot: first blank frame
per_frame_12=blanked = if(blank, 1, blanked);
per_frame_13=q6 = blank;                                   // shaders: bake / show blank pages
per_frame_14=q4 = if(blank, 0, max(0, min((age - THOLD) / TZOOM, 1)));  // zoom (0 once blank)

// --- flip cadence ---
// When the beat tracker is CONFIDENT (beat_conf), sync page turns to beat_onset
// (debounced by PMIN, with a PMAX fallback so it never stalls). When confidence is
// low, ignore beats and turn on a steady 0.4s. The blank end-flurry stays fast+fixed.
per_frame_15=FW = 0.15;                  // page-turn duration
per_frame_16=PMIN = 0.18;                // min seconds between beat-triggered flips
per_frame_17=PMAX = 1.2;                 // turn anyway if this long passes with no beat
per_frame_18=hiconf = above(beat_conf, 0.5);                       // beat tracker confident?
per_frame_19=ncbeat = above(beat_onset, 0.5) * above(time - last_t, PMIN);
per_frame_20=ncsync = max(ncbeat, above(time - last_t, PMAX));     // beat mode (+ silence fallback)
per_frame_21=ncsteady = above(time - last_t, 0.4);                 // low-confidence steady cadence
per_frame_22=nc = if(blank, above(time - last_t, 0.28), if(hiconf, ncsync, ncsteady));
// Also start a fresh page-turn (reset last_t) on the FIRST blank frame, so the
// zoomed page cuts straight into a blank turn (no un-zoomed filtered frame flashes).
per_frame_23=last_t = if(max(nc, enterblank), time, last_t);
per_frame_24=u = time - last_t;                   // time since this page turn began
per_frame_25=q1 = max(max(nc, enterblank), below(age, 0.06));  // warp: bake a new page now (age is per-preset; frame is global)
per_frame_26=q3 = min(u / FW, 1) * 1.5708;        // comp: page-turn angle 0..pi/2

// --- end after the blank flurry (ONE-SHOT: preset_complete is a latch the engine
// clears each frame; assert it for exactly one frame so it switches once cleanly) ---
per_frame_27=done = above(age, zend + TBLANK + 0.2);
per_frame_28=preset_complete = done * equal(fired, 0);
per_frame_29=fired = if(done, 1, fired);

