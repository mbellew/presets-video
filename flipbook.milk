shader_body
{
    if (q1 > 0.5)
    {
        if (q6 > 0.5)
        {
            // blank end-of-book page (the closing "empty pages" flurry)
            ret = float3(0.98, 0.97, 0.95);
        }
        else
        {
        // Pick one of five artistic filters per preset. filt_ is a 0..4 enum:
        //   0 watercolor   1 charcoal   2 line   3 comic   4 take-on-me
        // Set it to a literal to hardcode a filter, or int(rand_preset.x * 5.0)
        // for a random per-preset choice (rand_preset is constant per preset).
        int filt_ = int(floor(rand_preset.x * 4.9999));
        //int filt_ = 0;
        if (filt_ == 0)
        {
            // --- FILTER 0 - watercolor: Kuwahara, pick the flattest quadrant ---
            float2 px = texsize.zw * 3.0;   // sample step (bigger = fatter brush)
            float minv_ = 1e9;
            float3 best_ = float3(0, 0, 0);
            int si_; int sj_; int i_; int j_;
            for (si_ = -1; si_ <= 1; si_ = si_ + 2)
            {
                for (sj_ = -1; sj_ <= 1; sj_ = sj_ + 2)
                {

                    float3 sum_ = float3(0, 0, 0);
                    float ls_ = 0.0;
                    float l2_ = 0.0;
                    for (i_ = 0; i_ <= 4; i_ = i_ + 1)
                    {
                        for (j_ = 0; j_ <= 4; j_ = j_ + 1)
                        {
                            float2 o_ = float2(float(si_ * i_), float(sj_ * j_)) * px;
                            float3 c_ = GetVideo(uv + o_, 0.0).rgb;
                            float l_ = dot(c_, float3(0.299, 0.587, 0.114));
                            sum_ = sum_ + c_;
                            ls_  = ls_ + l_;
                            l2_  = l2_ + l_ * l_;
                        }
                    }
                    float n_ = 25.0;
                    float3 mean_ = sum_ / n_;
                    float var_ = l2_ / n_ - (ls_ / n_) * (ls_ / n_);
                    if (var_ < minv_) { minv_ = var_; best_ = mean_; }
                }
            }
            ret = best_;

            // --- push it: contrast, then heavy saturation, then posterize ---
            ret = saturate((ret - 0.5) * 1.35 + 0.5);          // contrast punch
            float g_ = dot(ret, float3(0.299, 0.587, 0.114));  // luminance
            ret = saturate(lerp(float3(g_, g_, g_), ret, 2.2)); // crank saturation
            ret = floor(ret * 5.0 + 0.5) / 5.0;                // 5 paint bands / channel

            // --- pop the subject: push the background toward white paper (seg mask) ---
            // seg_ ~ 1 on the person, ~ 0 on the background.
            float seg_ = MaskSeg(uv);
            float3 paper_ = float3(0.98, 0.97, 0.95);
            float3 bg_ = lerp(paper_, ret, 0.35);   // background = mostly white, faint ghost
            ret = lerp(bg_, ret, seg_);
        }
        else if (filt_ == 1)
        {
            // --- FILTER 1 - charcoal / pencil sketch ---
            // Sobel edges on video luminance -> dark strokes on warm paper, with
            // shading in the dark regions and a static paper-tooth grain.
            float2 e_ = texsize.zw * 2.0;
            float3 L_ = float3(0.299, 0.587, 0.114);
            float a00 = dot(GetVideo(uv + float2(-e_.x, -e_.y), 0.0).rgb, L_);
            float a10 = dot(GetVideo(uv + float2( 0.0,  -e_.y), 0.0).rgb, L_);
            float a20 = dot(GetVideo(uv + float2( e_.x, -e_.y), 0.0).rgb, L_);
            float a01 = dot(GetVideo(uv + float2(-e_.x,  0.0),  0.0).rgb, L_);
            float a11 = dot(GetVideo(uv,                        0.0).rgb, L_);
            float a21 = dot(GetVideo(uv + float2( e_.x,  0.0),  0.0).rgb, L_);
            float a02 = dot(GetVideo(uv + float2(-e_.x,  e_.y), 0.0).rgb, L_);
            float a12 = dot(GetVideo(uv + float2( 0.0,   e_.y), 0.0).rgb, L_);
            float a22 = dot(GetVideo(uv + float2( e_.x,  e_.y), 0.0).rgb, L_);
            float gx_ = (a20 + 2.0 * a21 + a22) - (a00 + 2.0 * a01 + a02);
            float gy_ = (a02 + 2.0 * a12 + a22) - (a00 + 2.0 * a10 + a20);
            float edge_ = sqrt(gx_ * gx_ + gy_ * gy_);

            float seg_ = MaskSeg(uv);
            float wgt_ = 0.35 + 0.65 * seg_;   // fainter strokes in the background

            // paper tooth grain (static per page, since baked on the gate frame)
            float2 nuv_ = uv * 3.0 + rand_frame.xy;
            float grain_ = tex2D(sampler_noise_lq, nuv_).x - 0.5;

            float tone_ = 0.94 * (0.55 + 0.45 * a11);              // soft mid grays
            tone_ = tone_ - saturate(edge_ * 3.5) * 0.85 * wgt_;   // dark edge strokes
            tone_ = tone_ - (1.0 - a11) * 0.35 * wgt_;             // shade dark regions
            tone_ = tone_ + grain_ * 0.08;                         // paper tooth
            tone_ = saturate(tone_);
            ret = tone_ * float3(1.0, 0.98, 0.95);                 // warm paper tint
        }
        else if (filt_ == 2)
        {
            // --- FILTER 2 - line drawing / pen-and-ink ---
            // Denser multi-scale Sobel contours PLUS diagonal cross-hatching that
            // builds up in the shadows, so the figure reads with form instead of a
            // sparse outline.
            float3 L_ = float3(0.299, 0.587, 0.114);
            float lum_ = dot(GetVideo(uv, 0.0).rgb, L_);

            // -- contours: combine a fine and a coarse Sobel for richer linework --
            float2 e1 = texsize.zw * 1.5;
            float b00 = dot(GetVideo(uv + float2(-e1.x, -e1.y), 0.0).rgb, L_);
            float b10 = dot(GetVideo(uv + float2( 0.0,  -e1.y), 0.0).rgb, L_);
            float b20 = dot(GetVideo(uv + float2( e1.x, -e1.y), 0.0).rgb, L_);
            float b01 = dot(GetVideo(uv + float2(-e1.x,  0.0),  0.0).rgb, L_);
            float b21 = dot(GetVideo(uv + float2( e1.x,  0.0),  0.0).rgb, L_);
            float b02 = dot(GetVideo(uv + float2(-e1.x,  e1.y), 0.0).rgb, L_);
            float b12 = dot(GetVideo(uv + float2( 0.0,   e1.y), 0.0).rgb, L_);
            float b22 = dot(GetVideo(uv + float2( e1.x,  e1.y), 0.0).rgb, L_);
            float g1x = (b20 + 2.0 * b21 + b22) - (b00 + 2.0 * b01 + b02);
            float g1y = (b02 + 2.0 * b12 + b22) - (b00 + 2.0 * b10 + b20);
            float edge1 = sqrt(g1x * g1x + g1y * g1y);

            float2 e2 = texsize.zw * 3.5;
            float c00 = dot(GetVideo(uv + float2(-e2.x, -e2.y), 0.0).rgb, L_);
            float c10 = dot(GetVideo(uv + float2( 0.0,  -e2.y), 0.0).rgb, L_);
            float c20 = dot(GetVideo(uv + float2( e2.x, -e2.y), 0.0).rgb, L_);
            float c01 = dot(GetVideo(uv + float2(-e2.x,  0.0),  0.0).rgb, L_);
            float c21 = dot(GetVideo(uv + float2( e2.x,  0.0),  0.0).rgb, L_);
            float c02 = dot(GetVideo(uv + float2(-e2.x,  e2.y), 0.0).rgb, L_);
            float c12 = dot(GetVideo(uv + float2( 0.0,   e2.y), 0.0).rgb, L_);
            float c22 = dot(GetVideo(uv + float2( e2.x,  e2.y), 0.0).rgb, L_);
            float g2x = (c20 + 2.0 * c21 + c22) - (c00 + 2.0 * c01 + c02);
            float g2y = (c02 + 2.0 * c12 + c22) - (c00 + 2.0 * c10 + c20);
            float edge2 = sqrt(g2x * g2x + g2y * g2y);

            float edge_ = max(edge1, edge2 * 0.4);          // favour fine scale = thinner lines
            float line_ = smoothstep(0.11, 0.24, edge_);    // higher threshold = fewer, thinner lines

            float seg_ = MaskSeg(uv);

            // -- shading: light posterized ink wash - FOREGROUND (subject) ONLY --
            float dark_ = saturate(1.0 - lum_);
            float wash_ = floor(dark_ * 3.0 + 0.5) / 3.0;      // ~4 flat tone bands
            float hatch_ = wash_ * 0.45 * seg_;                // wash only on the subject

            float wgt_ = 0.45 + 0.55 * seg_;                 // background lines stay lighter
            float ink_ = saturate(line_ + hatch_) * wgt_;
            float tone_ = saturate(0.97 - ink_ * 0.9);       // black ink on clean paper
            ret = float3(tone_, tone_, tone_);
        }
        else if (filt_ == 3)
        {
            // --- FILTER 3 - comic book: flat cels + Ben-Day halftone + ink ---
            float3 L_ = float3(0.299, 0.587, 0.114);
            float3 col_ = GetVideo(uv, 0.0).rgb;
            float lum_ = dot(col_, L_);

            // punch saturation, then quantize through a limited 4-color (CMYK)
            // process so colors snap to the classic comic ink set.
            col_ = saturate(lerp(float3(lum_, lum_, lum_), col_, 1.5));
            float3 cmy_ = 1.0 - col_;
            float k_ = min(cmy_.r, min(cmy_.g, cmy_.b));
            cmy_ = (cmy_ - k_) / max(1.0 - k_, 0.001);          // pull out the black
            cmy_ = floor(cmy_ * 2.0 + 0.5) / 2.0;               // C/M/Y screens: 0, 0.5, 1
            float kq_ = floor(k_ * 3.0 + 0.5) / 3.0;            // black screen in quarters
            col_ = (1.0 - cmy_) * (1.0 - kq_);

            // desaturate the background; subject keeps full color
            float seg_ = MaskSeg(uv);
            float clum_ = dot(col_, L_);
            col_ = lerp(float3(clum_, clum_, clum_), col_, 0.15 + 0.85 * seg_);

            // Ben-Day halftone: bigger, stronger dots that grow in the darker tones
            float2 gp = uv * texsize.xy;
            float cell_ = 16.0;
            float2 cq = gp / cell_;
            cq = (cq - floor(cq)) - 0.5;                        // position within a cell
            float dd_ = length(cq) * 2.0;                       // 0 center .. ~1.4 corner
            float rad_ = sqrt(saturate(1.0 - lum_)) * 1.15;     // darker -> bigger dot
            float dot_ = smoothstep(rad_, rad_ - 0.25, dd_);    // 1 inside the dot (sharper)
            col_ = col_ * (1.0 - dot_ * 0.45);

            // bold ink outlines (Sobel on luminance)
            float2 e_ = texsize.zw * 1.8;
            float k00 = dot(GetVideo(uv + float2(-e_.x, -e_.y), 0.0).rgb, L_);
            float k10 = dot(GetVideo(uv + float2( 0.0,  -e_.y), 0.0).rgb, L_);
            float k20 = dot(GetVideo(uv + float2( e_.x, -e_.y), 0.0).rgb, L_);
            float k01 = dot(GetVideo(uv + float2(-e_.x,  0.0),  0.0).rgb, L_);
            float k21 = dot(GetVideo(uv + float2( e_.x,  0.0),  0.0).rgb, L_);
            float k02 = dot(GetVideo(uv + float2(-e_.x,  e_.y), 0.0).rgb, L_);
            float k12 = dot(GetVideo(uv + float2( 0.0,   e_.y), 0.0).rgb, L_);
            float k22 = dot(GetVideo(uv + float2( e_.x,  e_.y), 0.0).rgb, L_);
            float kx_ = (k20 + 2.0 * k21 + k22) - (k00 + 2.0 * k01 + k02);
            float ky_ = (k02 + 2.0 * k12 + k22) - (k00 + 2.0 * k10 + k20);
            float ink_ = smoothstep(0.10, 0.30, sqrt(kx_ * kx_ + ky_ * ky_));
            col_ = col_ * (1.0 - ink_);

            ret = saturate(col_);
        }
        else
        {
            // --- FILTER 4 - "Take On Me" pencil rotoscope ---
            // B&W sketch: contour lines + loose back-and-forth pencil shading,
            // with a per-page "boil" - the sample coords jitter each baked page,
            // so the lines wobble page-to-page like hand-traced rotoscope.
            float3 L_ = float3(0.299, 0.587, 0.114);

            // per-page boil: offset the read by low-freq noise that changes each bake
            float2 jn_ = tex2D(sampler_noise_lq, uv * 2.0 + rand_frame.xy).xy - 0.5;
            float2 juv = uv + jn_ * texsize.zw * 7.0;

            // Sobel contours on the jittered image
            float2 e_ = texsize.zw * 1.6;
            float s00 = dot(GetVideo(juv + float2(-e_.x, -e_.y), 0.0).rgb, L_);
            float s10 = dot(GetVideo(juv + float2( 0.0,  -e_.y), 0.0).rgb, L_);
            float s20 = dot(GetVideo(juv + float2( e_.x, -e_.y), 0.0).rgb, L_);
            float s01 = dot(GetVideo(juv + float2(-e_.x,  0.0),  0.0).rgb, L_);
            float s11 = dot(GetVideo(juv,                        0.0).rgb, L_);
            float s21 = dot(GetVideo(juv + float2( e_.x,  0.0),  0.0).rgb, L_);
            float s02 = dot(GetVideo(juv + float2(-e_.x,  e_.y), 0.0).rgb, L_);
            float s12 = dot(GetVideo(juv + float2( 0.0,   e_.y), 0.0).rgb, L_);
            float s22 = dot(GetVideo(juv + float2( e_.x,  e_.y), 0.0).rgb, L_);
            float sx_ = (s20 + 2.0 * s21 + s22) - (s00 + 2.0 * s01 + s02);
            float sy_ = (s02 + 2.0 * s12 + s22) - (s00 + 2.0 * s10 + s20);
            float line_ = smoothstep(0.07, 0.22, sqrt(sx_ * sx_ + sy_ * sy_));

            // loose back-and-forth pencil shading: ONE scribble direction whose
            // stroke lines wave and wander (noise), so it reads as gestural
            // graphite fill rather than a mechanical hatch grid.
            float dark_ = saturate((1.0 - s11 - 0.05) * 1.25);
            float2 hp = (uv + jn_ * texsize.zw * 4.0) * texsize.xy;   // boils a touch too
            float2 dir_ = float2(0.86, 0.51);                        // scribble direction (~30 deg)
            float along_  = dot(hp, dir_);
            float across_ = dot(hp, float2(-dir_.y, dir_.x));
            // wave the stroke position + add noise so strokes wander (loose)
            float nwob_ = tex2D(sampler_noise_lq, uv * 5.0 + rand_frame.zw).x - 0.5;
            // two waves at different scales + noise => looser, wandering strokes
            across_ = across_ + sin(along_ * 0.05) * 10.0 + sin(along_ * 0.013) * 16.0 + nwob_ * 16.0;
            //float sc_ = across_ * 0.085;                            // stroke spacing
            float sc_ = across_ * 0.120;                            // stroke spacing
            sc_ = abs((sc_ - floor(sc_)) - 0.5) * 2.0;             // triangle line profile
            float stroke_ = 1.0 - smoothstep(0.30, 0.5, sc_);
            // break strokes into loose segments so most of the paper stays untouched
            float len_ = tex2D(sampler_noise_lq, float2(along_ * 0.004, across_ * 0.02)).x;
            float gap_ = smoothstep(0.40, 0.72, len_);            // most of each stroke drops out
            // only the darker shadows get any graphite (strong bias to white paper)
            float hatch_ = stroke_ * gap_ * smoothstep(0.45, 0.85, dark_) * 0.8;

            // graphite on off-white paper, high contrast, faintly cool (not warm)
            float ink_ = saturate(line_ + hatch_);
            float tone_ = saturate(0.98 - ink_ * 1.0);
            ret = float3(tone_, tone_, tone_) * float3(0.99, 0.99, 1.0);
        }

        // startup guard: video_frame_count is the number of frames uploaded to the
        // video history texture so far (0 before the first frame arrives; see
        // PresetShaderHeaderGlsl330.inc). Until real video exists, bake blank paper
        // so the opening pages are blank cover pages instead of black (also
        // graceful when there is no camera at all).
        ret = lerp(float3(0.98, 0.97, 0.95), ret, saturate(video_frame_count - 1.0));
        }   // end: else (not a blank end-page)
    }
    else
    {
        ret = tex2D(sampler_main, uv_orig).xyz;  // hold the painted frame
    }
}
